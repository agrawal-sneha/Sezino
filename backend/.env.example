# PostgreSQL connection string (replace with your actual database URL)
# Example for Neon: postgresql://user:password@ep-cool-breeze-123456.us-east-2.aws.neon.tech/dbname?sslmode=require
# Example for Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sezino?sslmode=disable"

# Server
JWT_SECRET="your-jwt-secret-key-change-in-production"
PORT=5000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:5000/api/auth/google/callback"

# Apple Sign In (optional)
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
APPLE_REDIRECT_URI="http://localhost:5000/api/auth/apple/callback"